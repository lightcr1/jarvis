# =============================================================================
# JARVIS — Production Environment Variables
# =============================================================================
# DO NOT commit real values. Copy this file to /etc/jarvis/jarvis.env,
# set all REQUIRED secrets, then restrict access:
#
#   sudo cp config/prod.env.example /etc/jarvis/jarvis.env
#   sudo chown root:jarvis /etc/jarvis/jarvis.env
#   sudo chmod 640 /etc/jarvis/jarvis.env
#   # Edit /etc/jarvis/jarvis.env and fill in all REQUIRED values
#   sudo systemctl start jarvis
#
# The systemd unit loads this file via EnvironmentFile=/etc/jarvis/jarvis.env
# =============================================================================

# =============================================================================
# CORE
# =============================================================================

# REQUIRED — set before deploying. Used to issue guest/device bearer tokens.
JARVIS_PASSPHRASE=

# REQUIRED — Change these from defaults before first boot.
JARVIS_DEFAULT_ADMIN_USERNAME=admin
JARVIS_DEFAULT_ADMIN_PASSWORD=

# OPTIONAL — Set to 1 to immediately block all write and dangerous actions.
JARVIS_EMERGENCY_STOP=0

# OPTIONAL — Comma-separated list of service targets JARVIS may act on.
ALLOWED_TARGETS=

# =============================================================================
# AI PROVIDER & ROUTING
# =============================================================================

# REQUIRED (for BYOK encrypted key storage) — generate with:
#   python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Keep this secret. Rotating it invalidates all stored BYOK keys (users re-enter).
JARVIS_SECRET_KEY=

# RECOMMENDED — OpenRouter is the default cloud provider (routes to many models).
# Set this key to enable cloud LLM. All other keys are optional fallbacks.
OPENROUTER_API_KEY=

# OPTIONAL — Direct provider keys (used if OpenRouter is not set or as BYOK fallback)
ANTHROPIC_API_KEY=
MISTRAL_API_KEY=
DEEPSEEK_API_KEY=

# OPTIONAL — Set to 0 to disable the AI router and use offline fallback only.
JARVIS_USE_AI_ROUTER=1

# OPTIONAL — Paths for billing/usage stores (defaults to /var/lib/jarvis/)
JARVIS_BYOK_STORE_PATH=/var/lib/jarvis/byok.json
JARVIS_CREDIT_STORE_PATH=/var/lib/jarvis/credits.json
JARVIS_USER_LIMITS_STORE_PATH=/var/lib/jarvis/user_limits.json
JARVIS_USAGE_LOG_PATH=/var/lib/jarvis/usage.log

# =============================================================================
# LLM PROVIDERS (legacy direct — used only when JARVIS_USE_AI_ROUTER=0)
# =============================================================================

# OPTIONAL — Which LLM to use: openai | gemini | local (auto-detected if unset)
LLM_PROVIDER=openai

# OPTIONAL — Direct OpenAI / Gemini keys (router uses OPENROUTER_API_KEY by default)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o
OPENAI_MAX_TOKENS=1024

GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# OPTIONAL — Local LLM via Ollama or llama.cpp
LOCAL_LLM_ENABLED=0
LOCAL_LLM_BASE_URL=http://localhost:11434
LOCAL_LLM_BACKEND=ollama

# =============================================================================
# VOICE — STT (Speech-to-Text)
# =============================================================================

# OPTIONAL — STT provider: local (faster-whisper) | gemini
STT_PROVIDER=local

# OPTIONAL — faster-whisper model size: tiny | base | small | medium | large
# Use small or medium in prod for better accuracy; large requires significant RAM.
WHISPER_MODEL=small

# OPTIONAL — faster-whisper compute type: int8 | float16 | float32
WHISPER_COMPUTE=int8

# =============================================================================
# VOICE — TTS (Text-to-Speech)
# =============================================================================

# OPTIONAL — TTS provider: edge-tts | piper | say (macOS only)
# Use piper in prod for fully offline operation; edge-tts requires internet.
TTS_PROVIDER=edge-tts

# OPTIONAL — edge-tts voice override
EDGE_TTS_VOICE=en-GB-RyanNeural
# EDGE_TTS_RATE=-5%
# EDGE_TTS_PITCH=-2Hz

# OPTIONAL — Piper (local, offline TTS — no internet dependency in prod)
# PIPER_BIN=/usr/local/bin/piper
# PIPER_MODEL=/var/lib/jarvis/models/en_GB-alan-medium.onnx

# OPTIONAL — Wakeword detection (requires always-on mic + wakeword engine)
JARVIS_WAKEWORD_ENABLED=false
JARVIS_WAKEWORD_PHRASE=hey jarvis

# =============================================================================
# HOME ASSISTANT
# =============================================================================

# REQUIRED (if using Home Assistant integration) — set before deploying
JARVIS_HA_BASE_URL=
# REQUIRED (if JARVIS_HA_BASE_URL is set) — long-lived access token from HA
JARVIS_HOME_ASSISTANT_TOKEN=

# OPTIONAL — Restrict remote HA actions to specific CIDRs
# JARVIS_HOME_ASSISTANT_REMOTE_ALLOWED_CIDRS=192.168.1.0/24

# OPTIONAL — Confirmation TTL for pending HA control requests (seconds)
JARVIS_HOME_ASSISTANT_CONFIRMATION_TTL_SEC=300

# =============================================================================
# PROXMOX
# =============================================================================

# REQUIRED (if using Proxmox integration) — set before deploying
PROXMOX_BASE_URL=
# REQUIRED (if PROXMOX_BASE_URL is set) — API token in format user@realm!tokenid=secret
PROXMOX_API_TOKEN=
# OPTIONAL — Path to multi-host config JSON
PROXMOX_HOSTS_FILE=/var/lib/jarvis/proxmox_hosts.json

# =============================================================================
# RAG — Knowledge Base (GitHub + WikiJS)
# =============================================================================

# REQUIRED (if using GitHub RAG) — set before deploying
# GITHUB_PAT=
# GITHUB_REPO=owner/repo
# GITHUB_BRANCH=main
# GITHUB_RAG_INCLUDE_EXTENSIONS=.md,.py,.ts,.yaml

# REQUIRED (if using WikiJS RAG) — set before deploying
# WIKIJS_GRAPHQL_URL=https://wiki.example.local/graphql
# WIKIJS_API_KEY=

# =============================================================================
# DATA PATHS & OPERATIONS
# =============================================================================

# OPTIONAL — Paths for persistent data (defaults to /var/lib/jarvis/)
JARVIS_AUDIT_LOG_PATH=/var/lib/jarvis/audit.log
JARVIS_CHAT_HISTORY_PATH=/var/lib/jarvis/chat_history.db
JARVIS_USER_STORE_PATH=/var/lib/jarvis/users.json
JARVIS_GROUP_STORE_PATH=/var/lib/jarvis/groups.json
JARVIS_MEMBERSHIP_STORE_PATH=/var/lib/jarvis/memberships.json
JARVIS_PERMISSION_STORE_PATH=/var/lib/jarvis/permissions.json
JARVIS_ADMIN_SETTINGS_PATH=/var/lib/jarvis/admin_settings.json
JARVIS_ADMIN_PASSWORD_STORE_PATH=/var/lib/jarvis/admin_passwords.json
JARVIS_USER_PREFERENCES_PATH=/var/lib/jarvis/user_preferences.json
JARVIS_MEMORY_PATH=/var/lib/jarvis/memory.json
# Billing/usage paths also set in AI PROVIDER section above; listed here for reference only.
# JARVIS_BYOK_STORE_PATH=/var/lib/jarvis/byok.json
# JARVIS_CREDIT_STORE_PATH=/var/lib/jarvis/credits.json
# JARVIS_USER_LIMITS_STORE_PATH=/var/lib/jarvis/user_limits.json
# JARVIS_USAGE_LOG_PATH=/var/lib/jarvis/usage.log

# OPTIONAL — Session/token settings
# Reduce TTL in prod for tighter session lifecycle control.
JARVIS_TOKEN_TTL_MIN=60
JARVIS_MAX_ACTIVE_TOKENS=10

# OPTIONAL — Auto-backup enabled in prod; rotates every 24h, keeps 7
JARVIS_AUTO_BACKUP_DISABLED=0
JARVIS_AUTO_BACKUP_INTERVAL_HOURS=24

# OPTIONAL — TLS (strongly recommended in prod for any remote/HTTPS access)
# Paths must be readable by the jarvis service user.
# JARVIS_TLS_CERT_FILE=/etc/jarvis/tls/fullchain.pem
# JARVIS_TLS_KEY_FILE=/etc/jarvis/tls/privkey.pem
