JARVIS_ENV=prod
JARVIS_HOST=0.0.0.0
JARVIS_PORT=443
JARVIS_PASSPHRASE=change-me-prod
JARVIS_DEFAULT_ADMIN_PASSWORD=change-me-prod
ALLOWED_TARGETS=local,web01
COOLDOWN_RESTART_SECONDS=60
COOLDOWN_CRITICAL_SECONDS=90

# AI Provider & Routing
JARVIS_SECRET_KEY=
OPENROUTER_API_KEY=
ANTHROPIC_API_KEY=
MISTRAL_API_KEY=
DEEPSEEK_API_KEY=
JARVIS_USE_AI_ROUTER=1
JARVIS_BYOK_STORE_PATH=/var/lib/jarvis/byok.json
JARVIS_CREDIT_STORE_PATH=/var/lib/jarvis/credits.json
JARVIS_USER_LIMITS_STORE_PATH=/var/lib/jarvis/user_limits.json
JARVIS_USAGE_LOG_PATH=/var/lib/jarvis/usage.log

# Legacy direct LLM keys (fallback when OpenRouter not set)
OPENAI_API_KEY=
GEMINI_API_KEY=

# Prod state must stay isolated and durable.
JARVIS_AUDIT_LOG_PATH=/var/lib/jarvis/audit.log
JARVIS_USER_STORE_PATH=/var/lib/jarvis/users.json
JARVIS_GROUP_STORE_PATH=/var/lib/jarvis/groups.json
JARVIS_MEMBERSHIP_STORE_PATH=/var/lib/jarvis/memberships.json
JARVIS_PERMISSION_STORE_PATH=/var/lib/jarvis/permissions.json
JARVIS_ADMIN_SETTINGS_PATH=/var/lib/jarvis/admin_settings.json
JARVIS_ADMIN_PASSWORD_STORE_PATH=/var/lib/jarvis/admin_passwords.json
JARVIS_USER_PREFERENCES_PATH=/var/lib/jarvis/user_preferences.json
JARVIS_CHAT_HISTORY_PATH=/var/lib/jarvis/chat_history.json
JARVIS_RAG_CACHE_PATH=/var/lib/jarvis/rag_cache.json
JARVIS_MEMORY_PATH=/var/lib/jarvis/memory.json

# Prod should enforce strict integrity gates.
JARVIS_INTEGRITY_FAIL_ON_ORPHANS=1
JARVIS_INTEGRITY_FAIL_ON_ADMIN_LOCKOUT=1
JARVIS_INTEGRITY_FAIL_ON_DUPLICATE_MEMBERSHIPS=1

# Default V1 stance: GitHub RAG is primary, WikiJS is not on the critical path.
JARVIS_WIKIJS_ENABLED=0
JARVIS_TOKEN_TTL_MIN=20
JARVIS_MAX_ACTIVE_TOKENS=200

# -------------------------------------------------------
# HTTPS / Nginx reverse proxy
# -------------------------------------------------------
# JARVIS runs on port 8000 (localhost only).
# Nginx proxies 443 → 8000 and redirects 80 → 443.
#
# Initial LAN setup (self-signed CA via mkcert):
#   sudo bash scripts/setup-https.sh
#   Cert is written to /etc/jarvis/ssl/cert.pem and key.pem.
#
# Public domain (Let's Encrypt):
#   sudo bash scripts/setup-https-letsencrypt.sh <your-domain.com>
#   Requires DNS A record and port 80 open to the internet.
#
# Nginx site config: deploy/nginx/jarvis.conf
# -------------------------------------------------------
