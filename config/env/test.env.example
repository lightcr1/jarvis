JARVIS_ENV=test
JARVIS_HOST=127.0.0.1
JARVIS_PORT=8010
JARVIS_PASSPHRASE=change-me-test
ALLOWED_TARGETS=local
COOLDOWN_RESTART_SECONDS=15
COOLDOWN_CRITICAL_SECONDS=30

# Test state must not overlap with dev/prod.
JARVIS_AUDIT_LOG_PATH=/var/lib/jarvis-test/audit.log
JARVIS_USER_STORE_PATH=/var/lib/jarvis-test/users.json
JARVIS_GROUP_STORE_PATH=/var/lib/jarvis-test/groups.json
JARVIS_MEMBERSHIP_STORE_PATH=/var/lib/jarvis-test/memberships.json
JARVIS_PERMISSION_STORE_PATH=/var/lib/jarvis-test/permissions.json
JARVIS_ADMIN_SETTINGS_PATH=/var/lib/jarvis-test/admin_settings.json
JARVIS_ADMIN_PASSWORD_STORE_PATH=/var/lib/jarvis-test/admin_passwords.json
JARVIS_USER_PREFERENCES_PATH=/var/lib/jarvis-test/user_preferences.json
JARVIS_CHAT_HISTORY_PATH=/var/lib/jarvis-test/chat_history.json
JARVIS_RAG_CACHE_PATH=/var/lib/jarvis-test/rag_cache.json
JARVIS_MEMORY_PATH=/var/lib/jarvis-test/memory.json

# Test should fail faster on drift.
JARVIS_INTEGRITY_FAIL_ON_ORPHANS=1
JARVIS_INTEGRITY_FAIL_ON_ADMIN_LOCKOUT=1
JARVIS_INTEGRITY_FAIL_ON_DUPLICATE_MEMBERSHIPS=1

JARVIS_WIKIJS_ENABLED=0
JARVIS_TOKEN_TTL_MIN=5
JARVIS_MAX_ACTIVE_TOKENS=25
