JARVIS_ENV=dev
JARVIS_HOST=0.0.0.0
JARVIS_PORT=443
JARVIS_PASSPHRASE=change-me-dev
ALLOWED_TARGETS=local
COOLDOWN_RESTART_SECONDS=15
COOLDOWN_CRITICAL_SECONDS=30

# Keep dev state isolated from test/prod.
JARVIS_AUDIT_LOG_PATH=/var/lib/jarvis-dev/audit.log
JARVIS_USER_STORE_PATH=/var/lib/jarvis-dev/users.json
JARVIS_GROUP_STORE_PATH=/var/lib/jarvis-dev/groups.json
JARVIS_MEMBERSHIP_STORE_PATH=/var/lib/jarvis-dev/memberships.json
JARVIS_PERMISSION_STORE_PATH=/var/lib/jarvis-dev/permissions.json
JARVIS_ADMIN_SETTINGS_PATH=/var/lib/jarvis-dev/admin_settings.json
JARVIS_ADMIN_PASSWORD_STORE_PATH=/var/lib/jarvis-dev/admin_passwords.json
JARVIS_USER_PREFERENCES_PATH=/var/lib/jarvis-dev/user_preferences.json
JARVIS_CHAT_HISTORY_PATH=/var/lib/jarvis-dev/chat_history.json
JARVIS_RAG_CACHE_PATH=/var/lib/jarvis-dev/rag_cache.json
JARVIS_MEMORY_PATH=/var/lib/jarvis-dev/memory.json

# Dev defaults should stay forgiving.
JARVIS_INTEGRITY_FAIL_ON_ORPHANS=0
JARVIS_INTEGRITY_FAIL_ON_ADMIN_LOCKOUT=0
JARVIS_INTEGRITY_FAIL_ON_DUPLICATE_MEMBERSHIPS=0

# Feature scope for local dev.
JARVIS_WIKIJS_ENABLED=0
JARVIS_TOKEN_TTL_MIN=20
JARVIS_MAX_ACTIVE_TOKENS=200
