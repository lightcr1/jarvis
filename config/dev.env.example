# =============================================================================
# JARVIS — Development Environment Variables
# =============================================================================
# Copy this file and source it for local development.
# DO NOT commit real secrets. This file contains safe development defaults.
#
# Usage:
#   cp config/dev.env.example .env
#   source .env && uvicorn jarvisappv4:app --reload
# =============================================================================

# =============================================================================
# CORE
# =============================================================================

# REQUIRED — Passphrase for guest/device bearer token issuance via POST /unlock
JARVIS_PASSPHRASE=dev-passphrase-change-me

# OPTIONAL — Bootstrap admin account (created on first run if admin store is empty)
JARVIS_DEFAULT_ADMIN_USERNAME=admin
JARVIS_DEFAULT_ADMIN_PASSWORD=admin123

# OPTIONAL — Kill switch: set to 1 to block all write and dangerous actions immediately
JARVIS_EMERGENCY_STOP=0

# OPTIONAL — Comma-separated service names that JARVIS may act on (restart, start, stop)
ALLOWED_TARGETS=local,web01

# =============================================================================
# AI PROVIDER & ROUTING
# =============================================================================

# OPTIONAL — Fernet master key for BYOK encryption. Generate with:
#   python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Leave blank in dev to run without BYOK (keys endpoint returns 503 without it).
# JARVIS_SECRET_KEY=

# OPTIONAL — Set your preferred cloud provider key for dev testing.
# OPENROUTER_API_KEY=sk-or-...
# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...
# GEMINI_API_KEY=...
# MISTRAL_API_KEY=...
# DEEPSEEK_API_KEY=...

# Set to 0 to force offline fallback (no cloud calls, useful for pure skill/HA dev).
JARVIS_USE_AI_ROUTER=1

# Dev billing/usage stores (under /tmp to avoid polluting /var/lib/jarvis)
JARVIS_BYOK_STORE_PATH=/tmp/jarvis/byok.json
JARVIS_CREDIT_STORE_PATH=/tmp/jarvis/credits.json
JARVIS_USER_LIMITS_STORE_PATH=/tmp/jarvis/user_limits.json
JARVIS_USAGE_LOG_PATH=/tmp/jarvis/usage.log

# =============================================================================
# LLM PROVIDERS (legacy direct — used only when JARVIS_USE_AI_ROUTER=0)
# =============================================================================

# OPTIONAL — Which LLM to use: openai | gemini | local (auto-detected if unset)
LLM_PROVIDER=openai

# OPTIONAL — OpenAI credentials and model settings
# OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o
OPENAI_MAX_TOKENS=1024

# OPTIONAL — Google Gemini credentials and model settings
# GEMINI_API_KEY=...
GEMINI_MODEL=gemini-2.0-flash

# OPTIONAL — Local LLM via Ollama or llama.cpp
LOCAL_LLM_ENABLED=0
LOCAL_LLM_BASE_URL=http://localhost:11434
LOCAL_LLM_BACKEND=ollama

# =============================================================================
# VOICE — STT (Speech-to-Text)
# =============================================================================

# OPTIONAL — STT provider: local (faster-whisper) | gemini
STT_PROVIDER=local

# OPTIONAL — faster-whisper model size: tiny | base | small | medium | large
WHISPER_MODEL=base

# OPTIONAL — faster-whisper compute type: int8 | float16 | float32
WHISPER_COMPUTE=int8

# =============================================================================
# VOICE — TTS (Text-to-Speech)
# =============================================================================

# OPTIONAL — TTS provider: edge-tts | piper | say (macOS only)
TTS_PROVIDER=edge-tts

# OPTIONAL — edge-tts voice override (en-GB-RyanNeural recommended for JARVIS feel)
EDGE_TTS_VOICE=en-GB-RyanNeural
# EDGE_TTS_RATE=-5%
# EDGE_TTS_PITCH=-2Hz

# OPTIONAL — Piper (local, offline TTS)
# PIPER_BIN=/usr/local/bin/piper
# PIPER_MODEL=/var/lib/jarvis/models/en_GB-alan-medium.onnx

# OPTIONAL — Wakeword detection
JARVIS_WAKEWORD_ENABLED=false
JARVIS_WAKEWORD_PHRASE=hey jarvis

# =============================================================================
# HOME ASSISTANT
# =============================================================================

# OPTIONAL — Home Assistant base URL and long-lived access token
# JARVIS_HA_BASE_URL=http://homeassistant.local:8123
# JARVIS_HOME_ASSISTANT_TOKEN=eyJ...

# OPTIONAL — Allowed CIDRs for remote HA actions (comma-separated)
# JARVIS_HOME_ASSISTANT_REMOTE_ALLOWED_CIDRS=192.168.1.0/24

# OPTIONAL — Confirmation TTL for pending HA control requests (seconds)
JARVIS_HOME_ASSISTANT_CONFIRMATION_TTL_SEC=300

# =============================================================================
# PROXMOX
# =============================================================================

# OPTIONAL — Default Proxmox host (multi-host config uses PROXMOX_HOSTS_FILE)
# PROXMOX_BASE_URL=https://pve.local:8006
# PROXMOX_API_TOKEN=root@pam!jarvis=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
# PROXMOX_HOSTS_FILE=/var/lib/jarvis/proxmox_hosts.json

# =============================================================================
# RAG — Knowledge Base (GitHub + WikiJS)
# =============================================================================

# OPTIONAL — GitHub personal access token and repo to index
# GITHUB_PAT=ghp_xxx
# GITHUB_REPO=owner/repo
# GITHUB_BRANCH=main
# GITHUB_RAG_INCLUDE_EXTENSIONS=.md,.py,.ts,.yaml

# OPTIONAL — WikiJS GraphQL endpoint and API key
# WIKIJS_GRAPHQL_URL=https://wiki.example.local/graphql
# WIKIJS_API_KEY=...

# =============================================================================
# DATA PATHS & OPERATIONS
# =============================================================================

# OPTIONAL — Data paths (dev uses /tmp/jarvis to avoid polluting /var/lib/jarvis)
JARVIS_AUDIT_LOG_PATH=/tmp/jarvis/audit.log
JARVIS_CHAT_HISTORY_PATH=/tmp/jarvis/chat_history.db
JARVIS_USER_STORE_PATH=/tmp/jarvis/users.json
JARVIS_MEMORY_PATH=/tmp/jarvis/memory.json

# OPTIONAL — Session/token settings
JARVIS_TOKEN_TTL_MIN=60
JARVIS_MAX_ACTIVE_TOKENS=10

# OPTIONAL — Auto-backup disabled in dev to avoid noise
JARVIS_AUTO_BACKUP_DISABLED=1
JARVIS_AUTO_BACKUP_INTERVAL_HOURS=24
