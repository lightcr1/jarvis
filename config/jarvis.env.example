JARVIS_PASSPHRASE=change-me
ALLOWED_TARGETS=local,web01
COOLDOWN_RESTART_SECONDS=60
COOLDOWN_CRITICAL_SECONDS=90

# Optional: Proxmox
# PROXMOX_BASE_URL=https://pve.local:8006
# PROXMOX_API_TOKEN=root@pam!jarvis=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
# PROXMOX_API_TOKEN_FORMAT=user@realm!tokenid=tokensecret

# Optional: Cloud LLM
# OPENAI_API_KEY=insert_here
# GEMINI_API_KEY=insert_here

# Optional: TTS
# PIPER_BIN=/usr/local/bin/piper
# PIPER_MODEL=/opt/models/en_US-amy-medium.onnx

# Optional: Kiosk
# KIOSK_URL=http://localhost:8000/

# Optional: local AI preparation
# LOCAL_LLM_ENABLED=0
# LOCAL_LLM_MODEL_DIR=/var/lib/jarvis/local-ai/models
# LOCAL_LLM_DEFAULT_MODEL=future-local-model

# Optional: learning memory
# JARVIS_MEMORY_PATH=/var/lib/jarvis/memory.json


# Optional: chat persistence
# JARVIS_CHAT_HISTORY_PATH=/var/lib/jarvis/chat_history.json

# Optional: RAG cache
# JARVIS_RAG_CACHE_PATH=/var/lib/jarvis/rag_cache.json

# Optional: Wiki.js RAG (GraphQL)
# WIKIJS_GRAPHQL_URL=https://wiki.example.local/graphql
# WIKIJS_API_KEY=insert_here
# WIKIJS_GRAPHQL_QUERY=query { pages { list(orderBy: TITLE) { title path description } } }

# Optional: GitHub RAG
# GITHUB_REPO=owner/repo
# GITHUB_BRANCH=main
# GITHUB_PAT=ghp_xxx
