JARVIS_PASSPHRASE=Lukas Engel
ALLOWED_TARGETS=local,web01
COOLDOWN_RESTART_SECONDS=60
COOLDOWN_CRITICAL_SECONDS=90

# Optional: Proxmox
# PROXMOX_BASE_URL=https://pve.local:8006
# PROXMOX_API_TOKEN=root@pam!jarvis=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
# PROXMOX_API_TOKEN_FORMAT=user@realm!tokenid=tokensecret

# Optional: Cloud LLM
# OPENAI_API_KEY=insert_here
# GEMINI_API_KEY=insert_here

# TTS — choose one provider:
#
# Option A: edge-tts (recommended — free Microsoft neural TTS, closest to original JARVIS)
#   Install: pip install edge-tts  (already in requirements.txt)
#   No API key needed. Requires internet access.
# TTS_PROVIDER=edge
# EDGE_TTS_VOICE=en-GB-RyanNeural    # British male — closest to original JARVIS
# EDGE_TTS_RATE=-5%                  # slightly slower
# EDGE_TTS_PITCH=-2Hz                # slightly deeper
#
# Option B: Piper (offline, local, no internet needed)
#   Download British voice: sudo bash scripts/install_piper_voice.sh
# TTS_PROVIDER=piper
# PIPER_BIN=/usr/local/bin/piper
# PIPER_MODEL=/opt/jarvis/models/en_GB-alan-medium.onnx
# PIPER_LENGTH_SCALE=1.10
# PIPER_NOISE_SCALE=0.45
# PIPER_NOISE_W=0.65

# Optional: Wakeword for voice-mode chat
# JARVIS_WAKEWORD_ENABLED=0
# JARVIS_WAKEWORD_PHRASE=hey jarvis

# Optional: Kiosk
# KIOSK_URL=http://localhost/

# Optional: local AI preparation
# LOCAL_LLM_ENABLED=0
# LOCAL_LLM_MODEL_DIR=/var/lib/jarvis/local-ai/models
# LOCAL_LLM_DEFAULT_MODEL=future-local-model

# Optional: learning memory
# JARVIS_MEMORY_PATH=/var/lib/jarvis/memory.json

# Optional: admin data stores (defaults used when unset)
# JARVIS_AUDIT_LOG_PATH=/var/lib/jarvis/audit.log
# JARVIS_USER_STORE_PATH=/var/lib/jarvis/users.json
# JARVIS_GROUP_STORE_PATH=/var/lib/jarvis/groups.json
# JARVIS_MEMBERSHIP_STORE_PATH=/var/lib/jarvis/memberships.json
# JARVIS_PERMISSION_STORE_PATH=/var/lib/jarvis/permissions.json
# JARVIS_ADMIN_SETTINGS_PATH=/var/lib/jarvis/admin_settings.json
# Optional: integrity-check strictness gates
# JARVIS_INTEGRITY_FAIL_ON_ORPHANS=0
# JARVIS_INTEGRITY_FAIL_ON_ADMIN_LOCKOUT=0
# JARVIS_INTEGRITY_FAIL_ON_DUPLICATE_MEMBERSHIPS=0


# Optional: chat persistence
# JARVIS_CHAT_HISTORY_PATH=/var/lib/jarvis/chat_history.json

# Optional: RAG cache
# JARVIS_RAG_CACHE_PATH=/var/lib/jarvis/rag_cache.json

# Optional: Wiki.js RAG (GraphQL)
# WIKIJS_GRAPHQL_URL=https://wiki.example.local/graphql
# WIKIJS_API_KEY=insert_here
# WIKIJS_GRAPHQL_QUERY=query { pages { list(orderBy: TITLE) { title path description } } }

# Optional: GitHub RAG
# GITHUB_REPO=owner/repo
# GITHUB_BRANCH=main
# GITHUB_PAT=ghp_xxx

# Optional: HTTPS for remote mic/browser secure context
# JARVIS_HOST=0.0.0.0
# JARVIS_PORT=443
# JARVIS_TLS_CERT_FILE=/etc/jarvis/tls/fullchain.pem
# JARVIS_TLS_KEY_FILE=/etc/jarvis/tls/privkey.pem

# Optional: Startup greeting (played at desktop login via jarvis-greeting.service)
# JARVIS_GREETING_SPEAK=1          # 1=speak via TTS, 0=silent
# JARVIS_GREETING_OPEN_BROWSER=1   # 1=open JARVIS in browser after greeting
# JARVIS_GREETING_BROWSER_DELAY=3  # seconds to wait before opening browser
# JARVIS_GREETING_HOST=127.0.0.1   # host to contact for the greeting API
